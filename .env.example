LLM_PROVIDER=ollama
OLLAMA_MODE=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_CHAT_TIMEOUT_SECONDS=90
BACKEND_BASE_URL=http://localhost:8000
STT_PROVIDER=onnx_asr
STT_MODEL=nemo-parakeet-tdt-0.6b-v3
STT_LANGUAGE=en
STT_MAX_DURATION_SECONDS=20
STT_ENABLED=true
# onnxruntime execution provider for speech-to-text. CPU is the reliable default;
# CoreMLExecutionProvider currently fails to load this model on macOS.
STT_EXECUTION_PROVIDERS=CPUExecutionProvider
