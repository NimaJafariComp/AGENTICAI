# LLM provider: ollama | openai | anthropic | mock
LLM_PROVIDER=ollama

# --- Ollama (local, default) ---
OLLAMA_MODE=local
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_CHAT_TIMEOUT_SECONDS=90

# --- OpenAI (set LLM_PROVIDER=openai and provide key) ---
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# --- Anthropic (set LLM_PROVIDER=anthropic and provide key) ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

BACKEND_BASE_URL=http://localhost:8000
STT_PROVIDER=onnx_asr
STT_MODEL=nemo-parakeet-tdt-0.6b-v3
STT_LANGUAGE=en
STT_MAX_DURATION_SECONDS=20
STT_ENABLED=true
# onnxruntime execution provider for speech-to-text. CPU is the reliable default;
# CoreMLExecutionProvider currently fails to load this model on macOS.
STT_EXECUTION_PROVIDERS=CPUExecutionProvider
